            "h": 0.7,
            "style": {
              "fontSize": 26,
              "bold": true
            }
          },
          {
            "id": "s04-left",
            "label": "方法说明",
            "type": "bullet-list",
            "items": [
              "理论框架或模型",
              "实验流程与变量设置",
              "样本、数据来源与评价指标"
            ],
            "x": 0.95,
            "y": 1.85,
            "w": 5.15,
            "h": 3.15,
            "style": {
              "fontSize": 17
            }
