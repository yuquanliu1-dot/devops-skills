{
  "id": "thesis-defense",
  "label": "毕业答辩 / 学术汇报",
  "description": "适合毕业答辩和学术汇报，强调研究问题、方法设计、数据结果、结论与答辩表达。",
  "briefSections": [
    "论文题目与答辩人信息",
    "研究背景与核心问题",
    "文献缺口与研究定位",
    "方法设计与实验流程",
    "结果数据与核心结论",
    "不足与未来工作"
  ],
  "starterDeck": {
    "meta": {
      "mode": "editable"
    },
    "slides": [
      {
        "id": "slide-01",
        "label": "封面",
        "type": "cover",
        "layoutVariant": "hero-left",
        "components": [
          {
            "id": "s01-title",
            "label": "课题标题",
            "type": "title",
            "text": "{{title}}",
            "x": 0.9,
            "y": 1.05,
            "w": 7.2,
            "h": 0.95,
            "style": {
              "fontSize": 30,
              "bold": true
            }
          },
          {
            "id": "s01-subtitle",
            "label": "答辩人信息",
            "type": "subtitle",
            "text": "答辩人 / 指导教师 / 专业 / 日期",
            "x": 0.95,
            "y": 2.2,
            "w": 6.3,
            "h": 0.45,
            "style": {
              "fontSize": 16,
              "color": "#475569"
            }
          },
          {
            "id": "s01-text",
            "label": "研究定位",
            "type": "text",
            "text": "在这里用一句话描述研究对象、核心问题或论文价值。",
            "x": 0.95,
            "y": 3.0,
            "w": 5.8,
            "h": 1.1,
            "style": {
              "fontSize": 18,
              "color": "#334155"
            }
          }
        ]
      },
      {
        "id": "slide-02",
